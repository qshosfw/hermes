{
  "name": "docs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build && pnpm run postbuild",
    "postbuild": "node -e \"const fs=require('fs'); const path=require('path'); const walk=(dir)=>{fs.readdirSync(dir).forEach(f=>{const p=path.join(dir,f); if(fs.statSync(p).isDirectory()) walk(p); else if(p.endsWith('.html')){ let c=fs.readFileSync(p,'utf8'); c=c.replace(/\\\"mode\\\":\\\"lazy\\\",\\\"manifestPath\\\":\\\"\\/__manifest\\\"/g, '\\\"mode\\\":\\\"eager\\\"'); fs.writeFileSync(p,c); }})}; walk('build/client');\"",
    "dev": "react-router dev",
    "start": "serve ./build/client --config ../../serve.json",
    "types:check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "build:pdf": "node scripts/generate-pdf.js"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/node": "^7.13.0",
    "@stablelib/poly1305": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fumadocs-core": "16.6.4",
    "fumadocs-mdx": "14.2.7",
    "fumadocs-mermaid": "^1.3.0",
    "fumadocs-ui": "16.6.4",
    "isbot": "^5.1.35",
    "lucide-react": "^0.570.0",
    "mermaid": "^11.12.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "rehype-katex": "^7.0.1",
    "remark-github-blockquote-alert": "^2.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "puppeteer": "^24.37.5",
    "react-router-devtools": "^6.2.0",
    "serve": "^14.2.5",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}